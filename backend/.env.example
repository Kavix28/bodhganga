# BodhGanga Backend — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Server
SERVER_PORT=9090

# MongoDB
MONGO_URI=mongodb://localhost:27017/bodhganga
# Production: MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/bodhganga

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRATION=86400000

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXX

# AWS S3
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=eu-north-1
AWS_S3_BUCKET=bodhganga-prod

# Email (Gmail SMTP — use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# CORS (production)
ALLOWED_ORIGINS=https://bodhganga.in,https://www.bodhganga.in

# MSG91 OTP
MSG91_AUTH_KEY=your-msg91-auth-key

# Google Drive Ingestion Pipeline
GOOGLE_DRIVE_PIPELINE_ENABLED=true
GOOGLE_DRIVE_CREDENTIALS_PATH=classpath:google-credentials.json
GOOGLE_DRIVE_SOURCE_FOLDER_ID=your-source-folder-id
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=your-archive-folder-id
